import java.util.*;
public class build{
    public static boolean isPalindrome(String s){
        String rev="";
        for(int i=s.length()-1;i>=0;i--){
            rev=rev+s.charAt(i);
        }return s.equals(rev);
    }

public static void main(String[]args){
    String s="madam";
if(isPalindrome(s)){
    System.out.println("The string is a palindrome.");
}else{
    System.out.println("The string is not a palindrome.");
}
}}
